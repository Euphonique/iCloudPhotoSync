#!/bin/sh
# Require Python 3 before install. DSM 7.2+ ships /usr/bin/python3; on
# DSM 7.1 it may need to be installed via Package Center or SynoCommunity
# (which puts it at /usr/local/bin/python3). We check early so install
# fails with a clear message instead of the app erroring out at runtime.
if ! command -v /usr/bin/python3 >/dev/null 2>&1 \
   && ! command -v /usr/local/bin/python3 >/dev/null 2>&1 \
   && ! command -v python3 >/dev/null 2>&1; then
    echo "iCloud Photo Sync requires Python 3. Please install Python 3 from Package Center or SynoCommunity first."
    echo "iCloud Photo Sync benötigt Python 3. Bitte zuerst Python 3 über das Paketzentrum oder SynoCommunity installieren."
    exit 1
fi
exit 0
